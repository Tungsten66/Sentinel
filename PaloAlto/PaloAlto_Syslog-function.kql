        SequenceNumber                 = tostring(p[36]),
        ActionFlags                    = tostring(p[37]),
        SourceCountry                  = tostring(p[38]),
        DestinationCountry             = tostring(p[39]),
        ContentType                    = tostring(p[41]),
        PCAP_ID                        = tostring(p[42]),
        FileDigest                     = tostring(p[43]),
        Cloud                          = tostring(p[44]),
        URLIndex                       = tostring(p[45]),
        UserAgent                      = tostring(p[46]),
        FileType                       = tostring(p[47]),
        X_Forwarded_For                = tostring(p[48]),
        Referer                        = tostring(p[49]),
        Sender                         = tostring(p[50]),
        Subject                        = tostring(p[51]),
        Recipient                      = tostring(p[52]),
        ReportID                       = tostring(p[53]),
        DeviceGroupHierarchyLevel1     = tostring(p[54]),
        DeviceGroupHierarchyLevel2     = tostring(p[55]),
        DeviceGroupHierarchyLevel3     = tostring(p[56]),
        DeviceGroupHierarchyLevel4     = tostring(p[57]),
        VirtualSystemName              = tostring(p[58]),
        DeviceName                     = tostring(p[59]),
        SourceVMUUID                   = tostring(p[61]),
        DestinationVMUUID              = tostring(p[62]),
        HTTPMethod                     = tostring(p[63]),
        TunnelIDIMSI                   = tostring(p[64]),
        MonitorTagIMEI                 = tostring(p[65]),
        ParentSessionID                = tostring(p[66]),
        ParentStartTime                = tostring(p[67]),
        TunnelType                     = tostring(p[68]),
        ThreatCategory                 = tostring(p[69]),
        ContentVersion                 = tostring(p[70]),
        SCTPAssociationID              = tostring(p[72]),
        PayloadProtocolID              = tostring(p[73]),
        HTTPHeaders                    = tostring(p[74]),
        URLCategoryList                = tostring(p[75]),
        RuleUUID                       = tostring(p[76]),
        HTTP2Connection                = tostring(p[77]),
        DynamicUserGroupName           = tostring(p[78]),
        XFFAddress                     = tostring(p[79]),
        SourceDeviceCategory           = tostring(p[80]),
        SourceDeviceProfile            = tostring(p[81]),
        SourceDeviceModel              = tostring(p[82]),
        SourceDeviceVendor             = tostring(p[83]),
        SourceDeviceOSFamily           = tostring(p[84]),
        SourceDeviceOSVersion          = tostring(p[85]),
        SourceHostname                 = tostring(p[86]),
        SourceMACAddress               = tostring(p[87]),
        DestinationDeviceCategory      = tostring(p[88]),
        DestinationDeviceProfile       = tostring(p[89]),
        DestinationDeviceModel         = tostring(p[90]),
        DestinationDeviceVendor        = tostring(p[91]),
        DestinationDeviceOSFamily      = tostring(p[92]),
        DestinationDeviceOSVersion     = tostring(p[93]),
        DestinationHostname            = tostring(p[94]),
        DestinationMACAddress          = tostring(p[95]),
        ContainerID                    = tostring(p[96]),
        PODNamespace                   = tostring(p[97]),
        PODName                        = tostring(p[98]),
        SourceExternalDynamicList      = tostring(p[99]),
