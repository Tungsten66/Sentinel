        ApplicationRisk                = tostring(p[114]),
        ApplicationCharacteristic      = iff(tostring(p[115]) == "__Q__", AppChar_Quoted, tostring(p[115])),
        ApplicationContainer           = tostring(p[116]),
        TunneledApplication            = tostring(p[117]),
        ApplicationSaaS                = tostring(p[118]),
        ApplicationSanctionedState     = tostring(p[119]),
        CloudReportID                  = tostring(p[120]),
        ClusterName                    = tostring(p[121]),
        FlowType                       = tostring(p[122])
    | project-away p, PAType, AppChar_Quoted
;
// SYSTEM — Description field [14] may contain commas; fields [15]+ may shift
let SYSTEM_LOG =
    PA_Syslogs
    | where PAType == "SYSTEM"
    | extend p = split(SyslogMessage, ",")
    | extend
        ReceiveTime                    = tostring(p[1]),
        SerialNumber                   = tostring(p[2]),
        Type                           = tostring(p[3]),
        Subtype                        = tostring(p[4]),
        GeneratedTime                  = tostring(p[6]),
        VirtualSystem                  = tostring(p[7]),
        EventID                        = tostring(p[8]),
        Object                         = tostring(p[9]),
        Module                         = tostring(p[12]),
        Severity                       = tostring(p[13]),
        Description                    = tostring(p[14]),
        SequenceNumber                 = tostring(p[15]),
        ActionFlags                    = tostring(p[16]),
        DeviceGroupHierarchyLevel1     = tostring(p[17]),
        DeviceGroupHierarchyLevel2     = tostring(p[18]),
        DeviceGroupHierarchyLevel3     = tostring(p[19]),
        DeviceGroupHierarchyLevel4     = tostring(p[20]),
        VirtualSystemName              = tostring(p[21]),
        DeviceName                     = tostring(p[22]),
        HighResolutionTimestamp        = tostring(p[25])
    | project-away p, PAType
;
