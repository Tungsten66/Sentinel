// Palo Alto Networks PAN-OS Syslog Parser — Microsoft Sentinel (Syslog table)
// PAN-OS 11.x/12.x field layout | Active log types: TRAFFIC, THREAT, SYSTEM, CONFIG | Last updated: 2026-06-17 v2.13
// Change Log:
// v2.13 | 2026-06-17 | Reintroduced scoped materialize on filtered base syslog set for faster multi-branch reuse.
// v2.1 | 2026-06-12 | Baseline parser refresh for PAN-OS 11.x/12.x with SD-WAN and quoted ApplicationCharacteristic handling.
// Field reference: https://docs.paloaltonetworks.com/pan-os/11-1/pan-os-admin/monitoring/use-syslog-for-monitoring/syslog-field-descriptions
// Index note: p[0]="1" (RFC 5424 prefix) — all p[] indices are +1 vs PAN-OS docs
// SD-WAN: TRAFFIC log normalizes the {path...} block at p[69]; THREAT/DECRYPTION/TUNNEL/GTP normalize quoted ApplicationCharacteristic
let PA_Syslogs = materialize(
    Syslog
    | where Facility == "user"
    | where SyslogMessage startswith "1,20"
    // Inactive type tokens (easy re-enable): ",HIPMATCH,", ",GLOBALPROTECT,", ",IPTAG,", ",USERID,", ",DECRYPTION,", ",TUNNEL,", ",SCTP,", ",AUTHENTICATION,", ",CORRELATION,", ",GTP,"
    | where SyslogMessage has_any (",TRAFFIC,", ",THREAT,", ",SYSTEM,", ",CONFIG,")
    | extend PAType = tostring(split(SyslogMessage, ",")[3])
    // Inactive types (easy re-enable): "HIPMATCH", "GLOBALPROTECT", "IPTAG", "USERID", "DECRYPTION", "TUNNEL", "SCTP", "AUTHENTICATION", "CORRELATION", "GTP"
    | where PAType in ("TRAFFIC", "THREAT", "SYSTEM", "CONFIG")
    | project TimeGenerated, EventTime, SeverityLevel, Computer, HostName, SyslogMessage, PAType
);
// TRAFFIC
let TRAFFIC_LOG =
    PA_Syslogs
    | where PAType == "TRAFFIC"
    | extend SD_WANPathInfo  = extract(@"\{([^}]+)\}", 1, SyslogMessage),
             AppChar_Quoted  = extract(@'"([^"]+)"', 1, SyslogMessage)
    | extend p = split(replace_regex(replace_regex(SyslogMessage, @"\{[^}]*\}", "__S__"), @'"[^"]*"', "__Q__"), ",")
    | extend
        ReceiveTime                    = tostring(p[1]),
        SerialNumber                   = tostring(p[2]),
        Type                           = tostring(p[3]),
        Subtype                        = tostring(p[4]),
        GeneratedTime                  = tostring(p[6]),
        SourceAddress                  = tostring(p[7]),
        DestinationAddress             = tostring(p[8]),
        NATSourceIP                    = tostring(p[9]),
        NATDestinationIP               = tostring(p[10]),
        RuleName                       = tostring(p[11]),
        SourceUser                     = tostring(p[12]),
        DestinationUser                = tostring(p[13]),
        Application                    = tostring(p[14]),
        VirtualSystem                  = tostring(p[15]),
        SourceZone                     = tostring(p[16]),
        DestinationZone                = tostring(p[17]),
        InboundInterface               = tostring(p[18]),
        OutboundInterface              = tostring(p[19]),
        LogAction                      = tostring(p[20]),
        SessionID                      = tostring(p[22]),
        RepeatCount                    = tostring(p[23]),
        SourcePort                     = tostring(p[24]),
        DestinationPort                = tostring(p[25]),
        NATSourcePort                  = tostring(p[26]),
        NATDestinationPort             = tostring(p[27]),
        Flags                          = tostring(p[28]),
        Protocol                       = tostring(p[29]),
        Action                         = tostring(p[30]),
        Bytes                          = tostring(p[31]),
        BytesSent                      = tostring(p[32]),
        BytesReceived                  = tostring(p[33]),
        Packets                        = tostring(p[34]),
        StartTime                      = tostring(p[35]),
        ElapsedTime                    = tostring(p[36]),
        Category                       = tostring(p[37]),
        SequenceNumber                 = tostring(p[39]),
        ActionFlags                    = tostring(p[40]),
        SourceCountry                  = tostring(p[41]),
        DestinationCountry             = tostring(p[42]),
        PacketsSent                    = tostring(p[44]),
        PacketsReceived                = tostring(p[45]),
        SessionEndReason               = tostring(p[46]),
        DeviceGroupHierarchyLevel1     = tostring(p[47]),
        DeviceGroupHierarchyLevel2     = tostring(p[48]),
        DeviceGroupHierarchyLevel3     = tostring(p[49]),
        DeviceGroupHierarchyLevel4     = tostring(p[50]),
        VirtualSystemName              = tostring(p[51]),
        DeviceName                     = tostring(p[52]),
        ActionSource                   = tostring(p[53]),
        SourceVMUUID                   = tostring(p[54]),
        DestinationVMUUID              = tostring(p[55]),
        TunnelIDIMSI                   = tostring(p[56]),
        MonitorTagIMEI                 = tostring(p[57]),
        ParentSessionID                = tostring(p[58]),
        ParentStartTime                = tostring(p[59]),
        TunnelType                     = tostring(p[60]),
        SCTPAssociationID              = tostring(p[61]),
        SCTPChunks                     = tostring(p[62]),
        SCTPChunksSent                 = tostring(p[63]),
        SCTPChunksReceived             = tostring(p[64]),
        RuleUUID                       = tostring(p[65]),
        HTTP2Connection                = tostring(p[66]),
        AppFlapCount                   = tostring(p[67]),
        PolicyID                       = tostring(p[68]),
        // SD-WAN: p[69] = raw {path...} block (normalized to __S__ above); named SD-WAN fields start at p[70].
        // ApplicationCharacteristic pre-extracted to AppChar_Quoted to bypass quoted comma corruption.
        SD_WANCluster                  = tostring(p[70]),
        SD_WANDeviceType               = tostring(p[71]),
        SD_WANClusterType              = tostring(p[72]),
        SD_WANSite                     = tostring(p[73]),
        DynamicUserGroupName           = tostring(p[74]),
        XFFAddress                     = tostring(p[75]),
        SourceDeviceCategory           = tostring(p[76]),
        SourceDeviceProfile            = tostring(p[77]),
        SourceDeviceModel              = tostring(p[78]),
        SourceDeviceVendor             = tostring(p[79]),
        SourceDeviceOSFamily           = tostring(p[80]),
        SourceDeviceOSVersion          = tostring(p[81]),
        SourceHostname                 = tostring(p[82]),
        SourceMacAddress               = tostring(p[83]),
        DestinationDeviceCategory      = tostring(p[84]),
        DestinationDeviceProfile       = tostring(p[85]),
        DestinationDeviceModel         = tostring(p[86]),
        DestinationDeviceVendor        = tostring(p[87]),
        DestinationDeviceOSFamily      = tostring(p[88]),
        DestinationDeviceOSVersion     = tostring(p[89]),
        DestinationHostname            = tostring(p[90]),
        DestinationMacAddress          = tostring(p[91]),
        ContainerID                    = tostring(p[92]),
        PODNamespace                   = tostring(p[93]),
        PODName                        = tostring(p[94]),
        SourceExternalDynamicList      = tostring(p[95]),
        DestinationExternalDynamicList = tostring(p[96]),
        HostID                         = tostring(p[97]),
        SerialNumber2                  = tostring(p[98]),
        SourceDynamicAddressGroup      = tostring(p[99]),
        DestinationDynamicAddressGroup = tostring(p[100]),
        SessionOwner                   = tostring(p[101]),
        HighResolutionTimestamp        = tostring(p[102]),
        ASliceServiceType              = tostring(p[103]),
        ASliceDifferentiator           = tostring(p[104]),
        ApplicationSubcategory         = tostring(p[105]),
        ApplicationCategory            = tostring(p[106]),
        ApplicationTechnology          = tostring(p[107]),
        ApplicationRisk                = tostring(p[108]),
        ApplicationCharacteristic      = iff(tostring(p[109]) == "__Q__", AppChar_Quoted, tostring(p[109])),
        ApplicationContainer           = tostring(p[110]),
        TunneledApplication            = tostring(p[111]),
        ApplicationSaaS                = tostring(p[112]),
        ApplicationSanctionedState     = tostring(p[113]),
        Offloaded                      = tostring(p[114]),
        FlowType                       = tostring(p[115]),
        ClusterName                    = tostring(p[116])
    | project-away p, PAType, AppChar_Quoted
;
// THREAT
