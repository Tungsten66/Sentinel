union isfuzzy=true
    TRAFFIC_LOG,
    THREAT_LOG,
    SYSTEM_LOG,
    CONFIG_LOG
    // ,HIPMATCH_LOG, GLOBALPROTECT_LOG, IPTAG_LOG, USERID_LOG
    // ,DECRYPTION_LOG, TUNNEL_LOG, SCTP_LOG, AUTHENTICATION_LOG
    // ,CORRELATION_LOG, GTP_LOG
| project-away SyslogMessage, ReceiveTime, SerialNumber